# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=organic_user
POSTGRES_PASSWORD=your-db-password-here
POSTGRES_DB=organic_care
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://organic_user:your-db-password-here@db:5432/organic_care
# URL for docker-compose (host = "db", password must be URL-encoded: @ → %40)
DATABASE_URL_DOCKER=postgresql+asyncpg://organic_user:your-db-password-url-encoded@db:5432/organic_care

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-your-openai-api-key-here
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_DIMENSIONS=1536

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-long-random-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
APP_NAME=Organic Care AI
BACKEND_CORS_ORIGINS=["http://localhost:4200","http://localhost:3000"]
LOG_LEVEL=INFO

# ── Frontend URL (used to build password-reset links) ─────────────────────────
FRONTEND_URL=http://localhost:4200

# ── Email / SMTP ──────────────────────────────────────────────────────────────
# For Gmail: enable 2FA → create an App Password at myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_TLS=true
SMTP_USER=your-gmail@gmail.com
SMTP_PASSWORD=your-gmail-app-password
SMTP_FROM=noreply@organiccare.ai

# ── Ingestion ─────────────────────────────────────────────────────────────────
USDA_API_KEY=your-usda-api-key-here
NUTRITIONIX_APP_ID=your-nutritionix-app-id
NUTRITIONIX_APP_KEY=your-nutritionix-app-key
INGESTION_FULL_CRON=0 2 * * 0
INGESTION_INCREMENTAL_CRON=0 3 * * *
